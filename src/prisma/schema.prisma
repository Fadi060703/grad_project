// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SystemSettings {
  id                          Int      @id @default(autoincrement())
  lecture_duration            Int?
  lectures_start_time         String?
  aided_pass_courses_number   Int?
  aided_marks_number          Int?
  theoretical_exam_date       DateTime?
  practical_exam_date         DateTime?
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt
  
  @@map("system_settings")
}

enum Role {

  ADMIN
  DOCTOR
  TEACHER
  STUDENT

}
model User {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  username     String   @unique
  full_name    String   
  phone_number  String?  
  role         Role
  is_active    Boolean  @default(true)
  password     String
  created_at   DateTime @default(now())
  updated_at   DateTime? @updatedAt
  student      Student?
  permissions  String[] @default([])
  
  // Course relations
  teachingCourses Course[] @relation("CourseTeachers")
  doctorCourses   Course[] @relation("CourseDoctors")

  @@map("users")
}
model Student {
  student_id Int @id @default( autoincrement() ) 
  userId Int @unique 
  user User @relation( fields: [ userId ] , references: [ id ] , onDelete: Cascade ) 
  mother_name String
}


model Year {
  id Int @id @default( autoincrement() ) 
  name String @unique
  has_majors Boolean @default(false)
  sections Section[]
  majors Major[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
}

model Section {
  id Int @id @default(autoincrement())
  name String
  year_id Int
  year Year @relation(fields: [year_id], references: [id], onDelete: Cascade)
  groups Group[]
  courses Course[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt

  @@unique([name, year_id]) 
}

model Major {
  id      Int     @id @default(autoincrement())
  name    String
  year_id Int
  year    Year    @relation(fields: [year_id], references: [id], onDelete: Cascade)
  groups  Group[]
  courses Course[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
  
  @@unique([name, year_id])
  @@map("majors")
}

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  section_id Int?
  section   Section?  @relation(fields: [section_id], references: [id], onDelete: Cascade)
  major_id   Int?
  major     Major?   @relation(fields: [major_id], references: [id], onDelete: SetNull)
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
  
  @@unique([name, section_id, major_id])
  @@map("groups")
}

model UniversityLocation {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  reaching_description String?
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
  
  @@map("university_locations")
}

enum CourseType {
  THEORITICAL_ONLY
  THEORITICAL_AND_PRACTICAL
}

enum ExamType {
  MSQ
  WRITTEN
}


model Course {
  id                  Int      @id @default(autoincrement())
  name                String
  course_type         CourseType
  exam_type           ExamType
  theoretical_grade   Int
  practical_grade     Int
  major_id             Int?
  major               Major?   @relation(fields: [major_id], references: [id], onDelete: SetNull)
  section_id           Int?
  section             Section? @relation(fields: [section_id], references: [id], onDelete: SetNull)
  doctors             User[]   @relation("CourseDoctors")
  teachers            User[]   @relation("CourseTeachers")
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt

  @@unique([name, major_id, section_id])
  @@map("courses")
}

model FAQ {
  id       Int     @id @default(autoincrement())
  question String?
  answer   String?
}

model Blog {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  image      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ExamGuideline {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

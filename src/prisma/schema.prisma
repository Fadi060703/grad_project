// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SystemSettings {
  id                          Int      @id @default(autoincrement())
  lecture_duration            Int?
  lectures_start_time         String?
  aided_pass_courses_number   Int?
  aided_marks_number          Int?
  theoretical_exam_date       DateTime?
  practical_exam_date         DateTime?
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt
  
  @@map("system_settings")
}

enum Role {

  ADMIN
  DOCTOR
  TEACHER
  STUDENT

}
model User {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  username     String   @unique
  full_name    String   
  phoneNumber  String?  
  role         Role
  is_active    Boolean  @default(true) 
  password     String
  created_at    DateTime @default(now()) 
  updated_at   DateTime @updatedAt
  student      Student?
  permissions  String[] @default([])

  @@map("users")
}
model Student {
  rollNum Int @id @default( autoincrement() ) 
  userId Int @unique 
  user User @relation( fields: [ userId ] , references: [ id ] , onDelete: Cascade ) 
  mothersName String 
  phoneNumber String 
}


model Year {
  id Int @id @default( autoincrement() ) 
  name String @unique
  sections Section[]
  majors Major[]
}

model Section {
  id Int @id @default(autoincrement())
  name String
  yearId Int
  year Year @relation(fields: [yearId], references: [id], onDelete: Cascade)
  groups Group[]
  @@unique([name, yearId]) 
}

model Major {
  id      Int     @id @default(autoincrement())
  name    String
  yearId  Int
  year    Year    @relation(fields: [yearId], references: [id], onDelete: Cascade)
  groups  Group[]
  
  @@unique([name, yearId])
  @@map("majors")
}

model Group {
  id        Int      @id @default(autoincrement())
  name      String
  sectionId Int
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  majorId   Int?
  major     Major?   @relation(fields: [majorId], references: [id], onDelete: SetNull)
  
  @@unique([name, sectionId])
  @@map("groups")
}

model UniversityLocation {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  reaching_description String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  
  @@map("university_locations")
}



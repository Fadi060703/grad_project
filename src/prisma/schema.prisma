// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model SystemSettings {
  id                        Int       @id @default(autoincrement())
  lecture_duration          Int?
  lectures_start_time       String?
  aided_pass_courses_number Int?
  aided_marks_number        Int?
  theoretical_exam_date     DateTime?
  practical_exam_date       DateTime?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  @@map("system_settings")
}

model FaculityInfo {
  id                             Int      @id @default(autoincrement())
  telegram_url                   String?
  facebook_url                   String?
  instagram_url                  String?
  linkedin_url                   String?
  website_url                    String?
  university_name                String?
  faculity_name                  String?
  faculity_picture_url           String?
  support_email                  String?
  lectures_schedule_url          String?
  theoritical_exam_schedule_url  String?
  practical_exam_schedule_url    String?
  created_at                     DateTime @default(now())
  updated_at                     DateTime @updatedAt

  @@map("faculity_info")
}

enum Role {
  ADMIN
  DOCTOR
  TEACHER
  STUDENT
}

model User {
  id           Int       @id @default(autoincrement())
  email        String?   @unique
  username     String    @unique
  full_name    String
  phone_number String?
  role         Role
  is_active    Boolean   @default(true)
  password     String
  created_at   DateTime  @default(now())
  updated_at   DateTime? @updatedAt
  student      Student?
  permissions  String[]  @default([])

  // Course relations
  teachingCourses Course[] @relation("CourseTeachers")
  doctorCourses   Course[] @relation("CourseDoctors")
  announcements   Announcement[] 
  @@map("users")
}
// Agreements (app logic responsibilities):
// - Student must always have year_id and group_id (both required in DB).
// - Student must have exactly one of section_id or major_id (mutually exclusive).
// - If section_id is set, major_id must be null; if major_id is set, section_id must be null.
// - Student.year_id must match the Year of the chosen Section or Major (denormalized year_id).
// - group_id must belong to the same Section or Major as the student (consistency check).
// - Student-course enrollment is many-to-many via StudentCourse, with enrollment_date and status.
// - Only allow enrollment in courses that match the student's year/section/major.
// - These rules are enforced in app logic .
model Student {
  student_id  Int    @id @default(autoincrement())
  userId      Int    @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  mother_name String
  year_id Int
  year Year @relation(fields: [year_id], references: [id], onDelete: Cascade)
  section_id Int?
  section Section? @relation(fields: [section_id], references: [id], onDelete: SetNull)
  major_id Int?
  major Major? @relation(fields: [major_id], references: [id], onDelete: SetNull)
  group_id Int
  group Group @relation(fields: [group_id], references: [id], onDelete: Cascade)
  courses StudentCourse[]
  marks Mark[]
}

model Year {
  id Int @id @default( autoincrement() ) 
  name String @unique
  order Int @unique
  has_majors Boolean @default(false)
  sections Section[]
  majors Major[]
  students Student[]
  announcements Announcement[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
}

model Section {
  id Int @id @default(autoincrement())
  name String
  year_id Int
  year Year @relation(fields: [year_id], references: [id], onDelete: Cascade)
  groups Group[]
  courses Course[]
  lectures Lecture[]
  students Student[]
  announcements Announcement[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt

  @@unique([name, year_id])
}

model Major {
  id      Int     @id @default(autoincrement())
  name    String
  year_id Int
  year    Year    @relation(fields: [year_id], references: [id], onDelete: Cascade)
  groups  Group[]
  courses Course[]
  lectures Lecture[]
  students Student[]
  announcements Announcement[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
  
  @@unique([name, year_id])
  @@map("majors")
}

model Group {
  id         Int       @id @default(autoincrement())
  name       String
  section_id Int?
  section    Section?  @relation(fields: [section_id], references: [id], onDelete: Cascade)
  major_id   Int?
  major     Major?   @relation(fields: [major_id], references: [id], onDelete: SetNull)
  announcements Announcement[]
  lecture Lecture[]
  students Student[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt
  
  @@unique([name, section_id, major_id])
  @@map("groups")
}

model UniversityLocation {
  id                   Int       @id @default(autoincrement())
  name                 String    @unique
  reaching_description String?
  created_at           DateTime  @default(now())
  updated_at           DateTime? @updatedAt
  lectures             Lecture[]

  @@map("university_locations")
}

enum CourseType {
  THEORITICAL_ONLY
  THEORITICAL_AND_PRACTICAL
}

enum ExamType {
  MSQ
  WRITTEN
}

model Course {
  id                  Int      @id @default(autoincrement())
  name                String
  course_type         CourseType
  exam_type           ExamType
  theoretical_grade   Int
  practical_grade     Int
  marks_course_id     Int?
  marks_course        MarksCourse? @relation(fields: [marks_course_id], references: [id], onDelete: SetNull)
  major_id             Int?
  major               Major?   @relation(fields: [major_id], references: [id], onDelete: SetNull)
  section_id           Int?
  section             Section? @relation(fields: [section_id], references: [id], onDelete: SetNull)
  doctors             User[]   @relation("CourseDoctors")
  teachers            User[]   @relation("CourseTeachers")
  lectures            Lecture[]
  students            StudentCourse[]
  announcements       Announcement[]
  created_at          DateTime @default(now())
  updated_at          DateTime? @updatedAt

  @@unique([name, major_id, section_id])
  @@map("courses")
}

model MarksCourse {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  courses    Course[]
  marks      Mark[]
  created_at DateTime @default(now())
  updated_at DateTime? @updatedAt
}

model Mark {
  id                Int      @id @default(autoincrement())
  marks_course_id   Int
  marks_course      MarksCourse @relation(fields: [marks_course_id], references: [id], onDelete: Cascade)
  student_id        Int
  student           Student   @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  practical_grade   Int
  theoretical_grade Int
  created_at        DateTime @default(now())
  updated_at        DateTime? @updatedAt

  @@unique([marks_course_id, student_id])
  @@index([marks_course_id])
  @@index([student_id])
}

enum StudentCourseStatus {
  ENROLLED
  PASSED
  FAILED
}

model StudentCourse {
  id Int @id @default(autoincrement())
  student_id Int
  student Student @relation(fields: [student_id], references: [student_id], onDelete: Cascade)
  course_id Int
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  enrollment_date DateTime @default(now())
  status StudentCourseStatus @default(ENROLLED)

  @@unique([student_id, course_id])
  @@map("student_courses")
}

model FAQ {
  id       Int     @id @default(autoincrement())
  question String?
  answer   String?
}

model Blog {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  image      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ExamGuideline {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

enum LectureType {
  THEORETICAL
  PRACTICAL
}

model Lecture {
  id           Int                 @id @default(autoincrement())
  title        String
  description  String?
  date         DateTime            @default(now())
  location_id  Int? // Reference to UniversityLocation
  location     UniversityLocation? @relation(fields: [location_id], references: [id], onDelete: SetNull)
  course_id    Int
  course       Course              @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lecture_type LectureType         @default(THEORETICAL)
  major_id     Int?
  major        Major?              @relation(fields: [major_id], references: [id], onDelete: SetNull)
  section_id   Int?
  section      Section?            @relation(fields: [section_id], references: [id], onDelete: SetNull)
  group_id     Int?
  group        Group?              @relation(fields: [group_id], references: [id], onDelete: SetNull)
  created_at   DateTime            @default(now())
  updated_at   DateTime            @updatedAt

  @@index([course_id])
  @@index([date])
  @@index([major_id])
  @@index([section_id])
  @@index([group_id])
  @@map("lectures")
}

enum AnnouncementType {
  REGULAR
  IMPORTANT
  EMERGENCY
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  type        AnnouncementType @default(REGULAR)
  attachments String[] @default([])
  
  // Target audience (all optional)
  year_id     Int?
  year        Year?    @relation(fields: [year_id], references: [id], onDelete: SetNull)
  section_id  Int?
  section     Section? @relation(fields: [section_id], references: [id], onDelete: SetNull)
  major_id    Int?
  major       Major?   @relation(fields: [major_id], references: [id], onDelete: SetNull)
  group_id    Int?
  group       Group?   @relation(fields: [group_id], references: [id], onDelete: SetNull)
  course_id   Int?
  course      Course?  @relation(fields: [course_id], references: [id], onDelete: SetNull)
  student_id  Int?
  student     User?    @relation(fields: [student_id], references: [id], onDelete: SetNull)
  
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([year_id])
  @@index([section_id])
  @@index([major_id])
  @@index([group_id])
  @@index([course_id])
  @@index([student_id])
  @@index([type])
  @@index([created_at])
  @@map("announcements")
}
